DATABASE_URL=postgresql://user:password@localhost:5432/ticketngn
PORT=3001

# Your wallet that receives nNGN payments
RECIPIENT_WALLET=0x...

# Arbitrum Sepolia RPC
ARB_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Admin PIN — this is what you type on the /admin/login page
ADMIN_SECRET=change-me-to-a-long-random-string

# Separate secret for signing JWTs
JWT_SECRET=change-me-to-another-long-random-string

# Frontend URL for CORS (dev: http://localhost:5173)
CLIENT_URL=http://localhost:5173
