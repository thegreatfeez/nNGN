# Arbitrum Sepolia RPC
ARB_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Deployed USDNGNOracle address (fill after forge create)
ORACLE_ADDRESS=

# Keeper wallet private key (NOT your deployer key — use a fresh wallet)
# Fund with ~0.05 ETH for gas (each update costs ~50k gas)
KEEPER_PRIVATE_KEY=

# ExchangeRate-API key — free tier at https://www.exchangerate-api.com
# Free tier: 1500 req/month. At 30-min intervals = 1440 req/month — fits comfortably.
EXCHANGE_RATE_API_KEY=

# How often to push price updates (milliseconds). Default: 1800000 (30 minutes)
# Reduce to 900000 (15 min) for a more responsive oracle during the hackathon demo
UPDATE_INTERVAL_MS=1800000
