# Arbitrum Sepolia
ARB_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
ARB_CHAIN_ID=421614
ARB_EXPLORER_URL=https://sepolia.arbiscan.io


# Your wallet address — also use for FEE_RECIPIENT
YOUR_ADDRESS=

# Protocol fee treasury (same as YOUR_ADDRESS is fine)
FEE_RECIPIENT=

# Chainlink ETH/USD on Arbitrum Sepolia
ETH_USD_FEED=0xd30e2101a97dcbAeBCBC04F14C3f624E67A35165

# USD/NGN oracle — fill AFTER running `make deploy-oracle`, paste the printed "Deployed to" address
USD_NGN_FEED=

# Initial price for USDNGNOracle constructor — NGN per 1 USD, scaled by 1e8
# Formula: rate × 1e8  →  1370 NGN/USD = 137000000000
# Rate as of 2026-06-02: ~₦1,370 per $1 (source: XE / Investing.com)
# The keeper updates this on-chain every 30 min after deploy — this is just the seed value.
# Used only by `make deploy-oracle`
INITIAL_NGN_RATE=137000000000

# Optional — set after `make deploy-anvil` to run `make test-feeds`
ENGINE_ADDRESS=

ETHERSCAN_API_KEY=